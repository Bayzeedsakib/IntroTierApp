@{}
@model List<BLL.DTOs.DepartmentDTO>

<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Update</th>
    </tr>

    @foreach(var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td><a href="/Department/Update/@item.Id">Update</a></td>
        </tr>
    }
</table>
